// wrangler.jsonc

{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "neokta-arb-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-25",

  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },

  "triggers": {
    "crons": [
      "*/3 * * * *"
    ]
  },

  "vars": {
    "INITIAL_USDC": "1000",

    "OKU_QUOTER_V2_ADDRESS": "0xaa52bB8110fE38D0d2d2AF0B85C3A3eE622CA455",

    // Alert on any positive full-route PnL
    "MIN_ALERT_PROFIT_USD": "0",

    // Optional stronger label for better opportunities
    "MIN_CONFIDENT_PROFIT_USD": "0.25",

    // Backward compatibility if parts of your code still read this
    "MIN_PROFIT_USD": "0.25",

    "ETHERLINK_RPC_URL": "https://node.mainnet.etherlink.com",
    "USDC_ADDRESS": "0x796Ea11Fa2dD751eD01b53C372fFDB4AAa8f00F9",

    "ENABLE_TELEGRAM_ALERTS": "true",
    "ENABLE_NEAR_MISS_ALERTS": "false",
    "ENABLE_IMBALANCE_ALERTS": "false",

    "NEAR_MISS_MIN_PNL_USD": "-1",
    "IMBALANCE_ALERT_THRESHOLD_PCT": "10",
    "MAX_ALERTS_PER_SCAN": "10",

    "LOG_LEVEL": "info"

  }
}
